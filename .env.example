# ============================================================================
# LLM
# ============================================================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# temperature for regular nodes (planner/researcher/writer/formatter)
LLM_TEMPERATURE=0.3
# temperature for deterministic nodes (grader/reviewer)
LLM_TEMPERATURE_DETERMINISTIC=0.0

# ============================================================================
# Search
# ============================================================================
TAVILY_API_KEY=tvly-...
TAVILY_MAX_RESULTS=3

# ============================================================================
# Database — CHANGE THE PASSWORD BEFORE DEPLOYING ANYWHERE REAL
# ============================================================================
POSTGRES_USER=research
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
POSTGRES_DB=research_db
DATABASE_URL=postgresql+psycopg://research:change-me-to-a-strong-random-password@localhost:5432/research_db

# ============================================================================
# Redis password — required by docker-compose (M-3)
# ============================================================================
REDIS_PASSWORD=change-me-to-a-strong-random-password

# ============================================================================
# Grafana admin password — required by docker-compose (M-4)
# ============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-to-a-strong-random-password

# ============================================================================
# Prometheus metrics scrape token (M-1) — leave empty to keep /metrics open
# ============================================================================
METRICS_TOKEN=

# ============================================================================
# App
# ============================================================================
DEBUG=true
MAX_REVISION_COUNT=2
# Hard timeout (seconds) on a single full graph invocation
GRAPH_TIMEOUT_SECONDS=300

# ============================================================================
# Retrieval cache (CRAG)
# ============================================================================
SIMILARITY_THRESHOLD=0.75
CACHE_TTL_DAYS=30
RETRIEVER_TOP_K=3
# max concurrent embedding calls (one per section)
EMBEDDING_MAX_CONCURRENCY=5

# ============================================================================
# API auth + rate-limit
# ============================================================================
# Leave RESEARCH_API_KEY empty to disable auth in dev.
RESEARCH_API_KEY=
# Separate admin key for destructive cache endpoints (DELETE /cache/*).
# Leave empty to disable those endpoints entirely (recommended in prod —
# route cache clearing through ops tooling rather than a web endpoint).
ADMIN_API_KEY=
RATE_LIMIT_PER_MINUTE=10

# ============================================================================
# Telegram bot
# ============================================================================
TELEGRAM_BOT_TOKEN=
API_BASE_URL=http://127.0.0.1:8000

# ============================================================================
# Observability
# ============================================================================
# human | json  —  'json' for production, 'human' for local dev
LOG_FORMAT=human
LOG_LEVEL=INFO

# Sentry DSN — leave empty to disable error tracking
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# prod | staging | dev
SENTRY_ENVIRONMENT=dev

# LangSmith (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=research-assistant
